APP_NAME="Palestine Creative Hub"
APP_TITLE="Palestine Creative Hub"
APP_EN_TITLE="Palestine Creative Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_FOLDER=
WEB_FOLDER=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=your-mail-host
MAIL_PORT=587
MAIL_USERNAME=your-mail-username
MAIL_PASSWORD=your-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_DEBUG=0
MAIL_HTML=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Custom Settings
FILE_MANAGER=false

# reCAPTCHA
CAPTCHA_SECRET=your-recaptcha-secret
CAPTCHA_SITEKEY=your-recaptcha-sitekey

# Payment Gateway (Bank of Palestine)
BOP_MERCHANT_ID=your-merchant-id
BOP_ACQUIRER_ID=000089
BOP_PASSWORD=your-bop-password
BOP_SUBMIT_URL=https://e-commerce.bop.ps/EcomPayment/RedirectAuthLink

# PalPay
PALPAY_USERNAME=your-palpay-username
PALPAY_PASSWORD=your-palpay-password

# SMS API
SMS_API_KEY=your-sms-api-key

# Email Addresses
FROM_EMAIL=your-email@example.com
NO_REPLY_EMAIL=noreply@example.com
CONTACT_US_EMAIL=contact@example.com
INQUIRY_EMAIL=inquiry@example.com
COMPLAINT_EMAIL=complaint@example.com
COPIES_REQUEST_EMAIL=copies@example.com
NOTIFICATION_EMAIL=notification@example.com

# Jobs.ps Webhook Configuration
JOBS_PS_PUBLIC_KEY_PATH=
JOBS_PS_SKIP_VERIFICATION=false
