<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On
    RewriteBase /PalestineCreativeHub/

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Serve media files directly from storage (bypass PHP for Imunify360 compatibility)
    RewriteCond /home/technopark/public_html/PalestineCreativeHub/storage/app/public/%1 -f
    RewriteRule ^media/(.+)$ storage/app/public/$1 [L]

    # Fall back to public/ directory for media files (images, js, etc.)
    RewriteCond /home/technopark/public_html/PalestineCreativeHub/public/%1 -f
    RewriteRule ^media/(.+)$ public/$1 [L]

    # If media file not found in storage or public, send to Laravel
    RewriteRule ^media/(.+)$ index.php [L]

    # Serve static files from public/ directory if they exist there
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond /home/technopark/public_html/PalestineCreativeHub/public/$1 -f
    RewriteRule ^(.+)$ public/$1 [L]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
